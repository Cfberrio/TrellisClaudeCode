# Meta Ads API — Discipline Rift (DR)
# Copy to .env in this directory. Never commit .env to version control.

# From Meta Developers console → App Dashboard
META_APP_ID=
META_APP_SECRET=

# System user token with ads_read permission (from Meta Business Settings)
META_SYSTEM_USER_TOKEN=

# Ad account ID — digits only, no act_ prefix
META_AD_ACCOUNT_ID=

# Graph API version
META_GRAPH_VERSION=v25.0
