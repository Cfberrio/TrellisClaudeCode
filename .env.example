# Google Ads API credentials
# Copy to .env and fill in real values. Never commit .env to version control.

# OAuth credentials (from Google Cloud Console)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# GOOGLE_ADS_LOGIN_CUSTOMER_ID: MCC / manager account ID (digits only, no dashes)
# Used by the Google Ads Python client for authentication.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_mcc_account_id_digits_only

# GOOGLE_ADS_CUSTOMER_ID: client account to run queries against (digits only, no dashes)
# This is the leaf account under the MCC. Metrics cannot be pulled at MCC level.
GOOGLE_ADS_CUSTOMER_ID=your_client_account_id_digits_only

# Required by the Google Ads Python client when using proto-plus message types.
GOOGLE_ADS_USE_PROTO_PLUS=true
